{
  "name": "doctor-tebar",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma full-stack de metodologia clinica aplicada de Eduardo Tebar Boti.",
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*",
    "e2e"
  ],
  "scripts": {
    "dev:web": "npm --workspace @doctor-tebar/web run dev",
    "dev:api": "npm --workspace @doctor-tebar/api run dev",
    "build": "npm run build --workspaces --if-present",
    "test": "npm --workspace @doctor-tebar/api run test && npm --workspace @doctor-tebar/web run test",
    "test:e2e": "npm --workspace @doctor-tebar/e2e run test",
    "lint": "npm run lint --workspaces --if-present",
    "deploy:web": "vercel --prod",
    "deploy:api:docs": "echo 'Deploy API from render.yaml in Render and set production env vars from docs/produccion.md'"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@tiptap/core": "^3.23.6",
    "@tiptap/extension-color": "^3.23.6",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-subscript": "^3.23.6",
    "@tiptap/extension-superscript": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-table-cell": "^3.23.6",
    "@tiptap/extension-table-header": "^3.23.6",
    "@tiptap/extension-table-row": "^3.23.6",
    "@tiptap/extension-task-item": "^3.23.6",
    "@tiptap/extension-task-list": "^3.23.6",
    "@tiptap/extension-text-align": "^3.23.6",
    "@tiptap/extension-text-style": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1"
  }
}
